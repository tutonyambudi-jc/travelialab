# Database
DATABASE_URL="file:./prisma/dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-a-long-random-secret"

# Cron secret: used to protect scheduled endpoints (set a strong value in production)
CRON_SECRET="replace-with-a-strong-random-secret"

# Demo seeding control: set to 'true' to create demo accounts (only for local/dev)
# When enabled you can set `ADMIN_PASSWORD`, otherwise demo users are skipped.
DEMO_SEED="false"
ADMIN_PASSWORD=""

# Devise (affichage) - conversion FC -> USD
# Exemple: 1 USD ≈ 600 FC (ajustez selon votre taux)
NEXT_PUBLIC_USD_FC_RATE=600
NEXT_PUBLIC_WIFI_PASS_PRICE_FC=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_PIECE_PRICE_FC=1000
NEXT_PUBLIC_EXTRA_BAGGAGE_OVERWEIGHT_PRICE_FC_PER_KG=200

# Payment Providers (optionnel)
MOBILE_MONEY_API_KEY=""
CARD_PAYMENT_API_KEY=""

# Support WhatsApp (optionnel — configurable aussi dans /admin/support/settings)
# Numéro en chiffres uniquement, indicatif pays (ex. 243…)
SUPPORT_WHATSAPP_NUMBER=""
SUPPORT_WHATSAPP_PREFILL=""

# SMTP Brevo — email transactionnel (recommandé)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="764f08002@smtp-brevo.com"
SMTP_PASS=""
SMTP_FROM_EMAIL=""
SMTP_FROM_NAME="Aigle Royale"
SMTP_SECURE="false"

# Brevo API — SMS transactionnels (et fallback email via API si SMTP indisponible)
# Doc API: https://developers.brevo.com/
BREVO_API_KEY=""
# Email expéditeur vérifié dans Brevo (fallback API)
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME="Aigle Royale"
# SMS : expéditeur alphanumérique (souvent 3–11 caractères). Numéros destinataires en E.164 (+243…)
BREVO_SMS_SENDER=""

# ─── Synchronisation ERP (BBS) ↔ Travelia ─────────────────────────────────────
# URL de base du serveur ERP (ex. https://erp.example.com ou http://localhost:3000 en dev)
ERP_BASE_URL=""
# Clé API partagée : envoyée par Travelia (Authorization: Bearer) et vérifiée sur les routes /api/erp/integrations/travelia/*
ERP_API_KEY=""
# Scopes accordés à cette clé côté ERP (liste séparée par des virgules, ou * pour tout en dev)
ERP_TRAVELIA_KEY_SCOPES="erp.travelia.bookings.write,erp.travelia.payments.write,erp.travelia.commissions.write,erp.travelia.status.read"
# Clé optionnelle pour appels machine aux routes /api/travelia/sync/* (sinon session admin requise)
TRAVELIA_INTERNAL_SYNC_API_KEY=""

